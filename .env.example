OPENAI_API_KEY=replace_me

# Optional. If unset, web_search will return setup guidance instead of failing.
TAVILY_API_KEY=replace_me

# You can change these after the first run.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=20000

# Optional. Use this only if you have an OpenAI-compatible gateway or proxy endpoint.
# Example: https://your-gateway.example.com/v1
OPENAI_BASE_URL=

# Required when OPENAI_BASE_URL points to a non-OpenAI domain.
# Only set this to true if you trust that gateway with your API key.
ALLOW_CUSTOM_OPENAI_BASE_URL=false

# Optional. Useful when your browser can access OpenAI through a proxy but terminal apps cannot.
# Common local proxy examples: http://127.0.0.1:7890, http://127.0.0.1:7897, http://127.0.0.1:1087
HTTPS_PROXY=

AGENT_MEMORY_FILE=.agent-memory.json
